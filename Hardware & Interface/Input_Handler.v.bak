module Input_Handler (
    input  wire clk_25MHz,
    input  wire rst_n,
    
    // Nút cứng trên board (Active-Low)
    input  wire key_up, key_down, key_left, key_right,
    
    // Tín hiệu từ Bàn phím PS/2 (Đã là Active-High)
    input  wire kb_up, kb_down, kb_left, kb_right,
    
    // Công tắc chọn nguồn chơi (0: Nút KIT, 1: Bàn phím)
    input  wire sw_mode,
    
    // Tín hiệu điều khiển hợp nhất xuất ra Game Logic (Active-High)
    output wire sys_up, sys_down, sys_left, sys_right,
    output wire sys_start, sys_reset
);

    // Dây tín hiệu đã được lọc nhiễu
    wire db_up, db_down, db_left, db_right;

    // Tái sử dụng module lọc nhiễu 4 lần (Cực kỳ gọn gàng)
    Button_Debouncer db1 (.clk_25MHz(clk_25MHz), .rst_n(rst_n), .btn_in(key_up),    .btn_out_high(db_up));
    Button_Debouncer db2 (.clk_25MHz(clk_25MHz), .rst_n(rst_n), .btn_in(key_down),  .btn_out_high(db_down));
    Button_Debouncer db3 (.clk_25MHz(clk_25MHz), .rst_n(rst_n), .btn_in(key_left),  .btn_out_high(db_left));
    Button_Debouncer db4 (.clk_25MHz(clk_25MHz), .rst_n(rst_n), .btn_in(key_right), .btn_out_high(db_right));

    // MUX: Chọn nguồn điều khiển
    assign sys_up    = sw_mode ? kb_up    : db_up;
    assign sys_down  = sw_mode ? kb_down  : db_down;
    assign sys_left  = sw_mode ? kb_left  : db_left;
    assign sys_right = sw_mode ? kb_right : db_right;

    // Dùng chung UP làm Start, DOWN làm Reset Menu
    assign sys_start = sys_up;    
    assign sys_reset = sys_down;  

endmodule