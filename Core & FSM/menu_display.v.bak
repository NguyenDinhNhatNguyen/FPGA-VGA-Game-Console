module menu_display(
    input  wire [9:0] x_pos,
    input  wire [9:0] y_pos,
    input  wire       video_on,
    input  wire [2:0] game_select,
    output reg  [9:0] R, G, B
);
    // Tọa độ lưới 3 cột, 3 hàng
    wire col0 = (x_pos >= 100 && x_pos <= 200);
    wire col1 = (x_pos >= 270 && x_pos <= 370);
    wire col2 = (x_pos >= 440 && x_pos <= 540);
    
    wire row0 = (y_pos >= 80  && y_pos <= 180);
    wire row1 = (y_pos >= 220 && y_pos <= 320);
    wire row2 = (y_pos >= 360 && y_pos <= 460);

    // Xác định 7 ô Game
    wire is_g0 = col0 && row0; // 0: Pong (Đỏ)
    wire is_g1 = col1 && row0; // 1: Snake (Xanh lá)
    wire is_g2 = col2 && row0; // 2: Flappy (Xanh lơ)
    wire is_g3 = col0 && row1; // 3: Breakout (Tím)
    wire is_g4 = col1 && row1; // 4: Dino (Trắng/Xám)
    wire is_g5 = col2 && row1; // 5: Invaders (Cam)
    wire is_g6 = col1 && row2; // 6: Tic-Tac-Toe (Vàng/Trắng)

    // Khung viền báo hiệu Game đang chọn
    wire border = (
        (game_select == 3'd0 && x_pos >= 90 && x_pos <= 210 && y_pos >= 70  && y_pos <= 190 && !is_g0) ||
        (game_select == 3'd1 && x_pos >= 260 && x_pos <= 380 && y_pos >= 70  && y_pos <= 190 && !is_g1) ||
        (game_select == 3'd2 && x_pos >= 430 && x_pos <= 550 && y_pos >= 70  && y_pos <= 190 && !is_g2) ||
        (game_select == 3'd3 && x_pos >= 90 && x_pos <= 210 && y_pos >= 210 && y_pos <= 330 && !is_g3) ||
        (game_select == 3'd4 && x_pos >= 260 && x_pos <= 380 && y_pos >= 210 && y_pos <= 330 && !is_g4) ||
        (game_select == 3'd5 && x_pos >= 430 && x_pos <= 550 && y_pos >= 210 && y_pos <= 330 && !is_g5) ||
        (game_select == 3'd6 && x_pos >= 260 && x_pos <= 380 && y_pos >= 350 && y_pos <= 470 && !is_g6)
    );

    always @(*) begin
        if (!video_on) begin
            {R, G, B} = 30'd0;
        end else if (border) begin 
            {R, G, B} = {10'h3FF, 10'h3FF, 10'h000}; // Viền Vàng
        end else if (is_g0) begin 
            {R, G, B} = {10'h3FF, 10'h000, 10'h000}; // Pong: Đỏ
        end else if (is_g1) begin 
            {R, G, B} = {10'h000, 10'h3FF, 10'h000}; // Snake: Xanh lá
        end else if (is_g2) begin 
            {R, G, B} = {10'h1FF, 10'h3FF, 10'h3FF}; // Flappy: Xanh lơ
        end else if (is_g3) begin 
            {R, G, B} = {10'h3FF, 10'h000, 10'h3FF}; // Breakout: Tím
        end else if (is_g4) begin 
            {R, G, B} = {10'h1FF, 10'h1FF, 10'h1FF}; // Dino: Xám nhạt
        end else if (is_g5) begin 
            {R, G, B} = {10'h3FF, 10'h1FF, 10'h000}; // Invaders: Cam
        end else if (is_g6) begin 
            {R, G, B} = {10'h3FF, 10'h3FF, 10'h3FF}; // Tic-Tac-Toe: Trắng
        end else begin 
            {R, G, B} = {10'h000, 10'h000, 10'h1FF}; // Nền Menu: Xanh dương
        end
    end
endmodule