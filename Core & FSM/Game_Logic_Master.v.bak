module Game_Logic_Master(
    input clk_25MHz, input rst_n,
    input btn_start, input btn_reset, input btn_left, input btn_right,
    input pong_dead, input snake_dead,
    output reg [1:0] current_state,
    output reg game_select, // 0: Pong, 1: Snake
    output init_en, output update_en
);
    localparam MENU=0, INIT=1, PLAY=2, GAMEOVER=3;
    reg [1:0] next_state;

    always @(posedge clk_25MHz or negedge rst_n) begin
        if (!rst_n) current_state <= MENU;
        else current_state <= next_state;
    end

    // Lưu lựa chọn Game
    always @(posedge clk_25MHz or negedge rst_n) begin
        if (!rst_n) game_select <= 0;
        else if (current_state == MENU) begin
            if (btn_left) game_select <= 0;
            if (btn_right) game_select <= 1;
        end
    end

    always @(*) begin
        case (current_state)
            MENU: next_state = btn_start ? INIT : MENU; // W để Start
            INIT: next_state = PLAY;
            PLAY: begin
                if ((game_select == 0 && pong_dead) || (game_select == 1 && snake_dead))
                    next_state = GAMEOVER;
                else next_state = PLAY;
            end
            GAMEOVER: next_state = btn_reset ? MENU : GAMEOVER; // S để Reset
            default: next_state = MENU;
        endcase
    end

    assign init_en = (current_state == INIT);
    assign update_en = (current_state == PLAY);
endmodule