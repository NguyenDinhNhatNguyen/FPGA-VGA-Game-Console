module breakout_logic(
    input  wire       clk, 
	 input  wire       rst_n, 
	 input  wire       init_en, 
	 input  wire       update_en, 
	 input  wire       SW_hard, 
	 input  wire       btn_left, 
	 input  wire       btn_right, 
    output reg  [9:0] bx, by, px, 
    output reg  [7:0] bricks, 
    output reg        dead
);
    reg signed [10:0] x, y, vx, vy; 
    reg [19:0] f_cnt; 
    wire [19:0] TICK_MAX = SW_hard ? 20'd208333 : 20'd416666;
    wire tick = (f_cnt >= TICK_MAX); 
    integer i;

    always @(*) begin bx = x[9:0]; by = y[9:0]; end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            dead <= 1'b0; 
        end else if (init_en) begin 
            {x, y, vx, vy, dead} <= {11'd320, 11'd400, 11'd3, -11'd3, 1'b0}; 
            px <= 10'd280; bricks <= 8'hFF; 
        end else if (update_en && !dead) begin
            if (btn_left && px > 0) px <= px - 10'd4; 
            else if (btn_right && px < 560) px <= px + 10'd4;
            
            f_cnt <= tick ? 20'd0 : f_cnt + 20'd1; 
            if (tick) begin
                x <= x + vx; y <= y + vy; 
                if (x <= 0 || x >= 630) vx <= -vx; 
                if (y <= 0) vy <= -vy; 
                if (y >= 470) dead <= 1'b1;
                
                if (y >= 440 && y <= 450 && x + 10 >= px && x <= px + 80) vy <= -vy;
                
                for (i = 0; i < 8; i = i + 1) begin
                    if (bricks[i] && y <= 70 && y >= 50 && x >= 40 + (i*70) && x <= 110 + (i*70)) begin 
                        bricks[i] <= 1'b0; vy <= -vy; 
                    end
                end
            end
        end
    end
endmodule