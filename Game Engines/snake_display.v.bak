module snake_display(
    input  wire video_on, 
    input  wire [1:0] current_state, 
    input  wire is_snake, 
    input  wire is_apple, 
    output reg  [9:0] VGA_R, 
    output reg  [9:0] VGA_G, 
    output reg  [9:0] VGA_B
);

    // Định nghĩa State FSM (Cho đồng bộ)
    localparam STATE_MENU     = 2'd0;
    localparam STATE_INIT     = 2'd1;
    localparam STATE_PLAY     = 2'd2;
    localparam STATE_GAMEOVER = 2'd3;

    // Định nghĩa bảng màu (10-bit)
    localparam COLOR_BLACK = 30'h00000000;
    localparam COLOR_BLUE  = {10'h000, 10'h000, 10'h3FF}; // Menu
    localparam COLOR_RED   = {10'h3FF, 10'h000, 10'h000}; // Táo / Màn hình Thua
    localparam COLOR_GREEN = {10'h000, 10'h3FF, 10'h000}; // Rắn

    always @(*) begin
        if (!video_on) begin
            // Vùng Blanking - Bắt buộc màu đen
            {VGA_R, VGA_G, VGA_B} = COLOR_BLACK;
        end 
        else begin
            case (current_state)
                STATE_MENU: begin
                    // Nền Menu màu Xanh
                    {VGA_R, VGA_G, VGA_B} = COLOR_BLUE;
                end
                
                STATE_PLAY, STATE_INIT: begin
                    // Ưu tiên hiển thị: Táo -> Rắn -> Nền đen
                    if (is_apple)
                        {VGA_R, VGA_G, VGA_B} = COLOR_RED;
                    else if (is_snake)
                        {VGA_R, VGA_G, VGA_B} = COLOR_GREEN;
                    else
                        {VGA_R, VGA_G, VGA_B} = COLOR_BLACK;
                end
                
                STATE_GAMEOVER: begin
                    // Nền Game Over màu Đỏ
                    {VGA_R, VGA_G, VGA_B} = COLOR_RED;
                end
                
                default: begin
                    {VGA_R, VGA_G, VGA_B} = COLOR_BLACK;
                end
            endcase
        end
    end

endmodule