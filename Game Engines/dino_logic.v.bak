module dino_logic(
    input  wire       clk,
	 input  wire       rst_n, 
	 input  wire       init_en, 
	 input  wire       update_en, 
	 input  wire       SW_hard, 
	 input  wire       btn_up, 
    output reg  [9:0] dino_y, 
	 output reg  [9:0] cactus_x, 
    output reg        dead
);
    reg signed [10:0] y, vy; 
    reg [19:0] f_cnt; 
    wire [19:0] TICK_MAX = SW_hard ? 20'd208333 : 20'd416666;
    wire tick = (f_cnt >= TICK_MAX);
    
    reg btn_up_delay; 
    always @(posedge clk) 
		  btn_up_delay <= btn_up; 
    wire jump = (btn_up && !btn_up_delay);

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            dead <= 1'b0; 
        end else if (init_en) begin 
            y <= 11'd350; vy <= 11'd0; 
				cactus_x <= 10'd640; 
				dead <= 1'b0; 
				end else if (update_en && !dead) begin 
					f_cnt <= tick ? 20'd0 : f_cnt + 20'd1; 
					if (tick) begin
						if (jump && y >= 350) vy <= -11'd12; 
						else if (y < 350) vy <= vy + 11'd1; 
						else vy <= 11'd0;
                
						y <= (y + vy > 350) ? 11'd350 : y + vy; 
						cactus_x <= (cactus_x == 0) ? 10'd640 : cactus_x - 10'd6; 
                
						if (cactus_x <= 130 && cactus_x >= 80 && y >= 320) dead <= 1'b1;
					end 
			end
		end
    always @(*) dino_y = y[9:0];
endmodule
