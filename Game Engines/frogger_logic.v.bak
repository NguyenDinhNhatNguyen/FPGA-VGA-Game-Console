module frogger_logic(
    input  wire clk_25MHz, rst_n, init_en, update_en,
    input  wire btn_up, btn_down, btn_left, btn_right,
    output reg  [9:0] frog_x, frog_y,
    output reg  [9:0] car1_x, car2_x, car3_x,
    output reg  dead, output reg [7:0] score
);
    reg [19:0] f_cnt;
    
    // BỘ SINH SỐ NGẪU NHIÊN LFSR
    reg [9:0] lfsr; 
    always @(posedge clk_25MHz) lfsr <= (lfsr == 0) ? 10'h3FF : {lfsr[8:0], lfsr[9] ^ lfsr[6]};

    // Tốc độ xe tăng dần khi điểm càng cao
    wire [19:0] speed = 20'd400_000 - (score * 20'd10_000);
    wire [19:0] TICK_MAX = (speed < 20'd100_000) ? 20'd100_000 : speed;
    wire tick = (f_cnt >= TICK_MAX);

    // Bắt cạnh nút nhấn
    reg u_d, d_d, l_d, r_d;
    always @(posedge clk_25MHz) {u_d, d_d, l_d, r_d} <= {btn_up, btn_down, btn_left, btn_right};
    wire p_up = btn_up & !u_d; wire p_dn = btn_down & !d_d;
    wire p_lf = btn_left & !l_d; wire p_rt = btn_right & !r_d;

    always @(posedge clk_25MHz or negedge rst_n) begin
        if (!rst_n || init_en) begin
            frog_x <= 10'd310; frog_y <= 10'd440; 
            dead <= 1'b0; score <= 8'd0; f_cnt <= 20'd0;
            // VỊ TRÍ XE RANDOM MỖI KHI VÀO GAME
            car1_x <= (lfsr % 400); 
            car2_x <= 10'd600 - (lfsr % 300); 
            car3_x <= 10'd100 + (lfsr % 200);
        end 
        else if (update_en && !dead) begin
            f_cnt <= tick ? 20'd0 : f_cnt + 20'd1;

            if (p_up && frog_y >= 10'd20) frog_y <= frog_y - 10'd20;
            if (p_dn && frog_y <= 10'd440) frog_y <= frog_y + 10'd20;
            if (p_lf && frog_x >= 10'd20) frog_x <= frog_x - 10'd20;
            if (p_rt && frog_x <= 10'd600) frog_x <= frog_x + 10'd20;

            if (tick) begin
                car1_x <= (car1_x > 10'd640) ? 10'd0   : car1_x + 10'd3; 
                car2_x <= (car2_x < 10'd5)   ? 10'd640 : car2_x - 10'd4; 
                car3_x <= (car3_x > 10'd640) ? 10'd0   : car3_x + 10'd5; 

                // RANDOM LẠI XE KHI ẾCH QUA BÊN KIA ĐƯỜNG AN TOÀN
                if (frog_y <= 10'd60) begin
                    score <= score + 8'd1;
                    frog_x <= 10'd310; frog_y <= 10'd440; 
                    car1_x <= (lfsr % 400); 
                    car2_x <= 10'd640 - (lfsr % 200);
                end

                // Va chạm
                if (frog_y < 370 && frog_y + 20 > 340 && frog_x < car1_x + 40 && frog_x + 20 > car1_x) dead <= 1'b1;
                if (frog_y < 270 && frog_y + 20 > 240 && frog_x < car2_x + 40 && frog_x + 20 > car2_x) dead <= 1'b1;
                if (frog_y < 170 && frog_y + 20 > 140 && frog_x < car3_x + 40 && frog_x + 20 > car3_x) dead <= 1'b1;
            end
        end
    end
endmodule