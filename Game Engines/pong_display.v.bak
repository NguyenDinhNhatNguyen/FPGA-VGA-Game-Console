module pong_display(
    input  wire [9:0] x_pos,
    input  wire [9:0] y_pos,
    input  wire video_on,
    
    // Tọa độ vật thể
    input  wire [9:0] ball_x,
    input  wire [9:0] ball_y,
    input  wire [9:0] paddle_L_y,
    input  wire [9:0] paddle_R_y, // Hỗ trợ 2 người chơi từ Code 2
    
    // Tín hiệu từ FSM
    input  wire [1:0] current_state, 
    
    // Output màu VGA (10-bit mỗi kênh)
    output reg  [9:0] VGA_R,
    output reg  [9:0] VGA_G,
    output reg  [9:0] VGA_B
);

    // 1. Khai báo tham số (Parameters) - Kế thừa từ Code 2 giúp dễ chỉnh sửa
    parameter BALL_SIZE  = 10;
    parameter PADDLE_W   = 10; // Đổi thành 10 (theo Code 1: x_pos từ 20 đến 32 là ~12, nhưng 10 chuẩn hơn)
    parameter PADDLE_H   = 60;
    parameter PADDLE_L_X = 20;
    parameter PADDLE_R_X = 610;

    // Trạng thái FSM
    localparam STATE_MENU     = 2'd0;
    localparam STATE_INIT     = 2'd1;
    localparam STATE_PLAY     = 2'd2;
    localparam STATE_GAMEOVER = 2'd3;

    // 2. Xác định vùng pixel có vật thể (Combinational Logic)
    wire ball_on     = (x_pos >= ball_x     && x_pos < ball_x + BALL_SIZE &&
                        y_pos >= ball_y     && y_pos < ball_y + BALL_SIZE);
                        
    wire paddle_L_on = (x_pos >= PADDLE_L_X && x_pos < PADDLE_L_X + PADDLE_W &&
                        y_pos >= paddle_L_y && y_pos < paddle_L_y + PADDLE_H);
                        
    wire paddle_R_on = (x_pos >= PADDLE_R_X && x_pos < PADDLE_R_X + PADDLE_W &&
                        y_pos >= paddle_R_y && y_pos < paddle_R_y + PADDLE_H);

    // 3. Xử lý hiển thị màu sắc
    always @(*) begin
        // Vùng Blanking (H-sync/V-sync): Bắt buộc phải tắt màu
        if (!video_on) begin
            {VGA_R, VGA_G, VGA_B} = 30'd0; 
        end 
        else begin
            case (current_state)
                STATE_MENU: begin
                    // Màn hình chờ Menu: Nền Xanh dương
                    {VGA_R, VGA_G, VGA_B} = {10'h000, 10'h000, 10'h3FF};
                end
                
                STATE_PLAY, STATE_INIT: begin
                    // Đang chơi: Kết hợp logic màu của Code 1
                    if (ball_on)
                        {VGA_R, VGA_G, VGA_B} = {10'h3FF, 10'h3FF, 10'h000}; // Bóng màu Vàng (Yellow)
                    else if (paddle_L_on || paddle_R_on)
                        {VGA_R, VGA_G, VGA_B} = {10'h3FF, 10'h3FF, 10'h3FF}; // Thanh trượt Trắng (White)
                    else
                        {VGA_R, VGA_G, VGA_B} = 30'd0;                       // Nền Đen (Black)
                end
                
                STATE_GAMEOVER: begin
                    // Thua game: Nền Đỏ
                    {VGA_R, VGA_G, VGA_B} = {10'h3FF, 10'h000, 10'h000};
                end
                
                default: begin
                    // Dự phòng an toàn
                    {VGA_R, VGA_G, VGA_B} = 30'd0;
                end
            endcase
        end
    end

endmodule