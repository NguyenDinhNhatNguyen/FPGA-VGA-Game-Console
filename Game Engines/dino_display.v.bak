module dino_display(
    input  wire [9:0] x_pos, 
	 input  wire [9:0] y_pos, 
	 input  wire [9:0] dino_y, 
	 input  wire [9:0] cactus_x, 
    input  wire       video_on, 
    output reg  [9:0] R, 
	 output reg  [9:0] G, 
	 output reg  [9:0] B
);
    wire is_dino   = (x_pos >= 100 && x_pos <= 130 && y_pos >= dino_y && y_pos <= dino_y + 40); 
    wire is_cactus = (x_pos >= cactus_x && x_pos <= cactus_x + 20 && y_pos >= 340 && y_pos <= 390); 
    wire is_ground = (y_pos >= 390 && y_pos <= 395);
    
    always @(*) begin
        if (!video_on) {R, G, B} = 30'd0; 
        else if (is_dino)   {R, G, B} = {10'h1FF, 10'h1FF, 10'h1FF}; 
        else if (is_cactus) {R, G, B} = {10'h000, 10'h3FF, 10'h000}; 
        else if (is_ground) {R, G, B} = {10'h3FF, 10'h3FF, 10'h3FF}; 
        else {R, G, B} = 30'd0;
    end
endmodule