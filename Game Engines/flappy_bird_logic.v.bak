module flappy_bird_logic(
    input clk_25MHz, input rst_n, input init_en, input update_en,
    input btn_up, // Nhấn W để bay lên
	 inp1ut SW_hard,
    oautput reg [9:0] bird_y,
    output reg [9:0] pipe_x,
   ưqa output reg dead
);
    reg signed [10:0] y, vy; // Tọa độ và vận tốc Y
    reg [19:0] f_cnt; 
    wire [19:0] TICK_MAX = SW_hard ? 20'd250_000 : 20'd416_666; // Hard: ống nước chạy nhanh hơn
    wire tick = (f_cnt >= TICK_MAX);
    
    // Bắt cạnh lên của phím W (tránh đè phím bay tuốt lên trời)
    reg btn_up_d;
    always @(posedge clk_25MHz) btn_up_d <= btn_up;
    wire jump = (btn_up && !btn_up_d);

    always @(posedge clk_25MHz or negedge rst_n) begin
        if (!rst_n) dead <= 0;
        else if (init_en) begin
            y <= 240; vy <= 0; pipe_x <= 640; dead <= 0;
        end 
        else if (update_en && !dead) begin
            f_cnt <= tick ? 0 : f_cnt + 1;
            if (tick) begin
                // 1. Xử lý Trọng lực và Nhảy
                if (jump) vy <= -6; // Lực nhảy hướng lên
                else if (vy < 8) vy <= vy + 1; // Trọng lực kéo xuống dần
                
                y <= y + vy;
                
                // 2. Di chuyển ống nước
                if (pipe_x == 0) pipe_x <= 640;
                else pipe_x <= pipe_x - 3; // Tốc độ ống
                
                // 3. Xử lý va chạm
                // Chạm đất hoặc trần
                if (y >= 460 || y <= 0) dead <= 1;
                // Chạm ống (Tọa độ chim X = 300, Ống rộng 40, Khoảng trống Y: 150 -> 250)
                if (pipe_x <= 320 && pipe_x >= 260) begin
                    if (y <= 150 || y >= 250) dead <= 1; // Rớt ngoài khoảng trống là chết
                end
            end
        end
    end
    always @(*) bird_y = y[9:0];
endmodule