module flappy_bird_display(
    input [9:0] x_pos, input [9:0] y_pos, input video_on,
    input [9:0] bird_y, input [9:0] pipe_x,
    output reg [9:0] R, output reg [9:0] G, output reg [9:0] B
);
    // Chim cố định ở X = 300, kích thước 20x20
    wire is_bird = (x_pos >= 300 && x_pos <= 320 && y_pos >= bird_y && y_pos <= bird_y + 20);
    
    // Ống nước rộng 40px, khoảng trống ở giữa từ Y=150 đến Y=250
    wire is_pipe = (x_pos >= pipe_x && x_pos <= pipe_x + 40 && (y_pos <= 150 || y_pos >= 250));

    always @(*) begin
        if (!video_on) {R, G, B} = 30'd0;
        else if (is_bird) {R, G, B} = {10'h3FF, 10'h3FF, 10'h000}; // Chim màu Vàng
        else if (is_pipe) {R, G, B} = {10'h000, 10'h3FF, 10'h000}; // Ống màu Xanh lá
        else {R, G, B} = {10'h1FF, 10'h3FF, 10'h3FF}; // Nền trời màu Xanh nhạt
    end
endmodule