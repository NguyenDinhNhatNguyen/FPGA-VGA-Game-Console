module invaders_display(
    input  wire [9:0] x_pos, 
	 input  wire [9:0] y_pos, 
	 input  wire [9:0] ship_x, 
	 input  wire [9:0] alien_x, 
	 input  wire [9:0] laser_x, 
	 input  wire [9:0] laser_y, 
    input  wire       alien_alive, 
	 input  wire       video_on, 
    output reg  [9:0] R, 
	 output reg  [9:0] G, 
	 output reg  [9:0] B
);
    wire is_ship  = (x_pos >= ship_x && x_pos <= ship_x + 40 && y_pos >= 420 && y_pos <= 450); 
    wire is_alien = alien_alive && (x_pos >= alien_x && x_pos <= alien_x + 40 && y_pos >= 50 && y_pos <= 90); 
    wire is_laser = (x_pos >= laser_x && x_pos <= laser_x + 4 && y_pos >= laser_y && y_pos <= laser_y + 20);
    
    always @(*) begin
        if (!video_on) {R, G, B} = 30'd0; 
        else if (is_alien) {R, G, B} = {10'h3FF, 10'h000, 10'h000}; 
        else if (is_ship)  {R, G, B} = {10'h000, 10'h000, 10'h3FF}; 
        else if (is_laser) {R, G, B} = {10'h3FF, 10'h3FF, 10'h000}; 
        else {R, G, B} = 30'd0;
    end
endmodule